package Ejercicios;

import javax.swing.*;

public class DetalleDeFactura1 {
    public static void main(String[] args) {

        /*crear una nueva clase con el método main llamada DetalleDeFactura,
        se requiere desarrollar un programa que reciba datos de la factura
        utilizando la clase Scanner*/


        //precios por kilo
        int precioKiloPalta = 3200;
        int precioKiloTomates = 1200;
        int precioKiloPapas = 2000;

        //preguntar qué quiere comprar
        String producto = JOptionPane.showInputDialog("¿Qué desea comprar? (palta/tomate/papa)");

        //preguntar cuántos kilos va a comprar
        String cantidadTexto = JOptionPane.showInputDialog("¿Cuántos kilos desea comprar?");

        //preguntar cantidad a numero
        int cantidad = 0;
        try { // INTENTA hacer esto (convertir a número)
            cantidad = Integer.parseInt(cantidadTexto);
        } catch (NumberFormatException e) {
            //dice: "el formato no es un número válido"
            // e = Variable que guarda la información del error

            // SI FALLA (porque escribieron letras), haz esto en su lugar
            JOptionPane.showInputDialog(null, "Error: debe ingresar un numero válido (entre 1 y 10 kilos): ");
            return; // sale del programa
        };


        //calcular pecio según el producto
        int precioTotal = 0;

        if (producto.equalsIgnoreCase("palta")) {
            precioTotal = precioKiloPalta * cantidad;
        } else if (producto.equalsIgnoreCase("tomate")) {
            precioTotal = precioKiloTomates * cantidad;
        } else if (producto.equalsIgnoreCase("papa")) {
            precioTotal = precioKiloPapas * cantidad;
        } else {
            JOptionPane.showMessageDialog(null, "producto no válido");
            return;
        }


        //mostrar el resultado
        JOptionPane.showMessageDialog(null,
                "Factura: \n" + producto + "\n" +
                        "Producto: \n" + cantidad + "kg \n" +
                        "Precio total: $" + precioTotal);
    }
}


