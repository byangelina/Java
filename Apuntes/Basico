package Apuntes;
public class Basico {
    public static void main() {

        // Para crear un nuevo archivo Java:
        // Dar clic derecho en src y crear una nueva Clase. Cada clase se escribe con la primera letra mayúscula siempre.

        // Así se imprime una variable tipo String, Int, etc:
        String variable = "Angela";
        System.out.println(variable);

        // Esto sirve para imprimir una cadena en mayúsculas: toUpperCase()
        // toUpperCase es un método. Hay varios para transformar las cadenas
        System.out.println(variable.toUpperCase());

        // Para las variables numéricas hay diferentes métodos
        Integer numero = 10;
        System.out.println(numero.byteValue());

        //

    }
}
